# GEMINI_API_KEY: Required for Gemini AI API calls (natural language search).
# Set this to your own Gemini API key when deploying.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
